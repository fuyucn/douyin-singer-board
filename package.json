{
  "name": "sususongboard",
  "private": true,
  "version": "0.0.39-13",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "sidecar:dev": "pnpm -F sidecar dev",
    "sidecar:build": "pnpm -F sidecar build",
    "sidecar:build:bin": "pnpm -F sidecar build:bin",
    "kugou-api:build:bin": "node scripts/build-kugou-api-bin.mjs",
    "tauri": "tauri",
    "tauri:dev": "pnpm sidecar:build && tauri dev",
    "tauri:build": "pnpm sidecar:build:bin && pnpm kugou-api:build:bin && tauri build",
    "bump": "node scripts/bump-patch.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-icons": "^1.3.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "@tauri-apps/plugin-sql": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@yao-pkg/pkg": "^6.3.0",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
