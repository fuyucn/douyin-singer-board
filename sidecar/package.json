{
  "name": "sidecar",
  "private": true,
  "version": "0.0.7",
  "type": "module",
  "main": "build/index.cjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=build/index.cjs",
    "build:bin": "node scripts/build-bin.mjs"
  },
  "dependencies": {
    "douyin-danma-listener": "^0.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@yao-pkg/pkg": "^6.3.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  },
  "pkg": {
    "scripts": [
      "build/index.cjs"
    ],
    "targets": [
      "node20"
    ]
  }
}
