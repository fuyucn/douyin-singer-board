{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认 capabilities: 主窗口可调用 sql/shell 插件 + 自定义命令",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "shell:allow-execute",
    "shell:allow-open",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    {
      "identifier": "sql:allow-load",
      "allow": [{ "name": "sqlite:sususingerboard.db" }]
    }
  ]
}
