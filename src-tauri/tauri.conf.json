{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SUSUSongBoard",
  "version": "0.0.39-37",
  "identifier": "com.sususongboard.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SUSUSongBoard",
        "width": 900,
        "height": 700,
        "resizable": true,
        "titleBarStyle": "Transparent",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  }
}
